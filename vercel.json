{
  "cleanUrls": false,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/coaching/:path*",
      "destination": "/학습코칭/:path*",
      "permanent": true
    },
    {
      "source": "/guide/:path*",
      "destination": "/학습가이드/:path*",
      "permanent": true
    },
    {
      "source": "/center/:path*",
      "destination": "/전국학원/:path*",
      "permanent": true
    },
    {
      "source": "/contact/:path*",
      "destination": "/상담문의/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
